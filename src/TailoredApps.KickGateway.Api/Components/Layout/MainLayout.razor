@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using TailoredApps.KickGateway.Api.Auth
<nav>
    <strong style="margin-right:1rem;color:#fff;">Kick Gateway</strong>
    <a href="/admin">Dashboard</a>
    <a href="/admin/clients">Clients</a>
    <a href="/admin/broadcasters">Broadcasters</a>
    <AuthorizeView Policy="@AdminPolicies.SuperAdminOnly">
        <a href="/admin/admins">Admins</a>
    </AuthorizeView>
    <span style="float:right;">
        <AuthorizeView>
            <Authorized>
                <span class="muted" style="margin-right:0.8rem;">@context.User.Identity?.Name</span>
                <a href="/api/auth/admin/logout">Sign out</a>
            </Authorized>
            <NotAuthorized>
                <a href="/api/auth/admin/login">Sign in</a>
            </NotAuthorized>
        </AuthorizeView>
    </span>
</nav>
<main>
    @Body
</main>
