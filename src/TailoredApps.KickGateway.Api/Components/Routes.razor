@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <main>
                            <div class="card" style="max-width: 480px; margin: 4rem auto;">
                                <h1>Kick Gateway Admin</h1>
                                <p>Sign in with your Kick account to continue. Only enrolled admins can access the panel.</p>
                                <p><a href="/api/auth/admin/login"><button>Sign in with Kick</button></a></p>
                            </div>
                        </main>
                    }
                    else
                    {
                        <main>
                            <div class="card" style="max-width: 480px; margin: 4rem auto;">
                                <h1>Forbidden</h1>
                                <p class="muted">You're signed in as <strong>@context.User.Identity.Name</strong> but don't have permission for this page.</p>
                                <p><a href="/admin">Back to dashboard</a> · <a href="/api/auth/admin/logout">Sign out</a></p>
                            </div>
                        </main>
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>
