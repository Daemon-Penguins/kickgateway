@page "/admin/broadcasters"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using TailoredApps.KickGateway.Api.Auth
@using TailoredApps.KickGateway.Api.Services
@inject IDbContextFactory<KickGatewayDbContext> DbFactory
@inject NavigationManager Nav
@inject IServiceScopeFactory ScopeFactory
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject ClipsCatalogService Catalog

<h1>Broadcasters</h1>
<p class="muted">Each row is one Kick channel connected under one client app. Use "Connect" to begin a fresh OAuth flow for a channel.</p>

<div class="card">
    <h3>Connect a broadcaster</h3>
    @if (_clientChoices is null || _clientChoices.Count == 0)
    {
        <p class="muted">Add a client app first.</p>
    }
    else
    {
        <label><span>Client app</span>
            <select @bind="_chosenClientId">
                @foreach (var c in _clientChoices)
                {
                    <option value="@c.Id">@c.Name (@c.ClientId)</option>
                }
            </select>
        </label>
        <button @onclick="StartConnect">Start OAuth</button>
        <p class="muted">Opens Kick's consent screen for the selected client app. After approval you're redirected back and a broadcaster row appears below.</p>
    }
</div>

<div class="card">
    <h3>Connected broadcasters</h3>
    @if (_rows is null)
    {
        <p>Loading…</p>
    }
    else if (_rows.Count == 0)
    {
        <p class="muted">None yet.</p>
    }
    else
    {
        <div class="table-scroll">
        <table>
            <thead>
                <tr><th>Channel</th><th>Client app</th><th>Subscriptions</th><th>Token expires</th><th>Status</th><th>OBS clips</th><th></th></tr>
            </thead>
            <tbody>
            @foreach (var b in _rows)
            {
                <tr>
                    <td><strong>@b.Username</strong><br /><span class="muted">@b.KickUserId · @b.ChannelSlug</span></td>
                    <td>@b.KickClientApp?.Name</td>
                    <td>@b.Subscriptions.Count</td>
                    <td><span class="muted">@b.AccessTokenExpiresAt.ToString("u")</span></td>
                    <td>@(b.IsEnabled ? new MarkupString("<span class='pill green'>enabled</span>") : new MarkupString("<span class='pill red'>disabled</span>"))</td>
                    <td>
                        @if (b.ClipsDisplayEnabled)
                        {
                            <a href="@ObsUrl(b.ChannelSlug)" target="_blank" rel="noopener">Preview</a>
                            <button class="secondary" @onclick="() => CopyObsUrl(b.ChannelSlug)">Copy URL</button>
                            @if (CanManageClips(b))
                            {
                                <button class="secondary" @onclick="() => OpenClipsEditor(b)">Settings</button>
                                <button class="secondary" @onclick="() => ToggleClips(b.Id)">Hide</button>
                            }
                            <br /><span class="muted">@ClipsSummary(b)</span>
                        }
                        else
                        {
                            <span class="muted">hidden</span>
                            @if (CanManageClips(b))
                            {
                                <button class="secondary" @onclick="() => ToggleClips(b.Id)">Show</button>
                            }
                        }
                    </td>
                    <td>
                        @if (CanEnroll(b))
                        {
                            <button @onclick="() => Enroll(b.Id)">Enroll all events</button>
                        }
                        @if (CanToggle(b))
                        {
                            <button class="secondary" @onclick="() => Toggle(b.Id)">@(b.IsEnabled ? "Disable" : "Enable")</button>
                        }
                    </td>
                </tr>
                @if (_clipsEditId == b.Id)
                {
                    <tr>
                        <td colspan="7" style="background:#0e1116;">
                            <div style="display:flex;gap:1.2rem;align-items:center;flex-wrap:wrap;padding:0.4rem 0;">
                                <strong>Clip player — @b.Username</strong>
                                <label><span>Order</span>
                                    <select @bind="_editSort">
                                        <option value="@ClipsSortMode.Latest">Latest (newest first)</option>
                                        <option value="@ClipsSortMode.MostViewed">Most viewed</option>
                                    </select>
                                </label>
                                @if (_editSort == ClipsSortMode.MostViewed)
                                {
                                    <label><span>Time window</span>
                                        <select @bind="_editWindow">
                                            <option value="@ClipsTimeWindow.All">All time</option>
                                            <option value="@ClipsTimeWindow.Day">Today</option>
                                            <option value="@ClipsTimeWindow.Week">This week</option>
                                            <option value="@ClipsTimeWindow.Month">This month</option>
                                        </select>
                                    </label>
                                }
                                <label><span>Shuffle</span> <input type="checkbox" @bind="_editShuffle" /></label>
                                @if (_editShuffle)
                                {
                                    <label><span>Play first, in order</span>
                                        <input type="number" min="0" max="20" style="width:5rem;" @bind="_editLeadIn" />
                                    </label>
                                }
                                <button @onclick="() => SaveClipsSettings(b.Id)">Save</button>
                                <button class="secondary" @onclick="CancelClipsEditor">Cancel</button>
                            </div>
                            <span class="muted">
                                @(_editShuffle
                                    ? $"Plays the top {_editLeadIn} {(_editSort == ClipsSortMode.MostViewed ? "most-viewed" : "newest")} clip(s) first, then random picks forever."
                                    : $"Plays all clips in {(_editSort == ClipsSortMode.MostViewed ? "most-viewed" : "newest-first")} order, on loop.")
                            </span>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_lastEnrollResult))
{
    <div class="card">
        <h3>Last enrollment result</h3>
        <pre style="background:#0e1116;color:#cdd6ff;padding:0.8rem;border-radius:4px;font-size:0.8rem;overflow:auto;">@_lastEnrollResult</pre>
    </div>
}

@code {
    List<KickBroadcasterAccount>? _rows;
    List<KickClientApp>? _clientChoices;
    Guid _chosenClientId;
    string? _lastEnrollResult;

    ClaimsPrincipal _user = new(new ClaimsIdentity());

    protected override async Task OnInitializedAsync()
    {
        _user = (await AuthState.GetAuthenticationStateAsync()).User;
        await Reload();
    }

    async Task Reload()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        // Only client apps the user can administer should appear in the connect dropdown
        // (StartConnect needs ClientAdmin on the chosen client).
        IQueryable<KickClientApp> clientQ = db.ClientApps.Where(x => x.IsEnabled);
        if (!_user.IsSuperAdmin())
        {
            var canAdmin = _user.ClientRoles()
                .Where(x => x.Role == AdminRole.ClientAdmin)
                .Select(x => x.ClientAppId)
                .ToHashSet();
            clientQ = clientQ.Where(c => canAdmin.Contains(c.Id));
        }
        _clientChoices = await clientQ.OrderBy(x => x.Name).ToListAsync();
        if (_chosenClientId == Guid.Empty && _clientChoices.Count > 0) _chosenClientId = _clientChoices[0].Id;

        IQueryable<KickBroadcasterAccount> rowQ = db.Broadcasters
            .Include(x => x.KickClientApp).Include(x => x.Subscriptions);
        if (!_user.IsSuperAdmin())
        {
            var visible = _user.AccessibleClientAppIds();
            rowQ = rowQ.Where(b => visible.Contains(b.KickClientAppId));
        }
        _rows = await rowQ.OrderBy(x => x.Username).ToListAsync();
    }

    bool CanEnroll(KickBroadcasterAccount b) =>
        _user.HasClientRoleAtLeast(b.KickClientAppId, AdminRole.ClientOperator);

    bool CanToggle(KickBroadcasterAccount b) =>
        _user.HasClientRoleAtLeast(b.KickClientAppId, AdminRole.ClientAdmin);

    bool CanManageClips(KickBroadcasterAccount b) =>
        _user.HasClientRoleAtLeast(b.KickClientAppId, AdminRole.ClientOperator);

    // Public OBS browser-source URL for this channel's clip reel.
    string ObsUrl(string slug) => $"{Nav.BaseUri.TrimEnd('/')}/obs/clips/{Uri.EscapeDataString(slug)}";

    async Task CopyObsUrl(string slug)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", ObsUrl(slug)); }
        catch { /* clipboard blocked (insecure context / denied) — Preview link still works */ }
    }

    // --- per-channel clip player settings editor ---
    Guid? _clipsEditId;
    ClipsSortMode _editSort;
    ClipsTimeWindow _editWindow;
    int _editLeadIn = 2;
    bool _editShuffle = true;

    string ClipsSummary(KickBroadcasterAccount b)
    {
        var order = b.ClipsSortMode == ClipsSortMode.MostViewed
            ? "most viewed" + (b.ClipsTimeWindow == ClipsTimeWindow.All ? "" : $" ({b.ClipsTimeWindow.ToString().ToLowerInvariant()})")
            : "latest";
        return b.ClipsShuffle ? $"{order} · {b.ClipsLeadInCount} first, then shuffle" : $"{order} · in order";
    }

    void OpenClipsEditor(KickBroadcasterAccount b)
    {
        if (!CanManageClips(b)) return;
        _clipsEditId = b.Id;
        _editSort = b.ClipsSortMode;
        _editWindow = b.ClipsTimeWindow;
        _editLeadIn = b.ClipsLeadInCount;
        _editShuffle = b.ClipsShuffle;
    }

    void CancelClipsEditor() => _clipsEditId = null;

    async Task SaveClipsSettings(Guid id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var b = await db.Broadcasters.FindAsync(id);
        if (b is null) return;
        if (!CanManageClips(b)) return;        // server-side check; UI hides the button too
        b.ClipsSortMode = _editSort;
        b.ClipsTimeWindow = _editWindow;
        b.ClipsLeadInCount = Math.Clamp(_editLeadIn, 0, 50);
        b.ClipsShuffle = _editShuffle;
        b.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
        Catalog.InvalidateChannel(b.ChannelSlug);   // settings take effect immediately
        _clipsEditId = null;
        await Reload();
    }

    async Task ToggleClips(Guid id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var b = await db.Broadcasters.FindAsync(id);
        if (b is null) return;
        if (!CanManageClips(b)) return;        // server-side check; UI hides the button too
        b.ClipsDisplayEnabled = !b.ClipsDisplayEnabled;
        b.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
        await Reload();
    }

    void StartConnect()
    {
        if (_chosenClientId == Guid.Empty) return;
        Nav.NavigateTo($"/api/auth/kick/start?clientAppId={_chosenClientId}", forceLoad: true);
    }

    async Task Toggle(Guid id)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var b = await db.Broadcasters.FindAsync(id);
        if (b is null) return;
        if (!CanToggle(b)) return;            // server-side check; UI hides the button too
        b.IsEnabled = !b.IsEnabled;
        b.UpdatedAt = DateTime.UtcNow;
        await db.SaveChangesAsync();
        await Reload();
    }

    async Task Enroll(Guid id)
    {
        // Permission check first — the row could have been swapped via dev-tools
        // before we got here; the in-process call below has no claims context.
        var target = _rows?.FirstOrDefault(b => b.Id == id);
        if (target is null || !CanEnroll(target)) return;

        // Call the enrollment service in-process. The previous HTTP-self-loopback
        // (Blazor → /api/subscriptions/{id}/enroll → 10× Kick POST) overflowed
        // the 30 s standard HttpClient resilience timeout and crashed the circuit.
        await using var scope = ScopeFactory.CreateAsyncScope();
        var enroll = scope.ServiceProvider.GetRequiredService<SubscriptionEnrollmentService>();
        var (ok, error, results) = await enroll.EnrollAllAsync(id);
        _lastEnrollResult = JsonSerializer.Serialize(
            new { ok, error, results },
            new JsonSerializerOptions { WriteIndented = true });
        await Reload();
    }
}
